{
  "$id": "https://open-metadata.org/schema/entity/data/pipeline.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Self-contained version of the official OpenMetadata Pipeline entity schema. Source: https://github.com/open-metadata/OpenMetadata/blob/main/openmetadata-spec/src/main/resources/json/schema/entity/data/pipeline.json  External $ref definitions (entityReference, tagLabel, basic types) have been inlined. The tagLabel definition is relaxed to only require 'tagFQN' since the app only reads that field and upstream responses may omit labelType/state/source.",
  "title": "Pipeline",
  "description": "This schema defines the Pipeline entity. A pipeline enables the flow of data from source to destination through a series of processing steps.",
  "type": "object",
  "definitions": {
    "entityReference": {
      "type": "object",
      "description": "Inlined from type/entityReference.json",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "fullyQualifiedName": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "deleted": { "type": "boolean" },
        "inherited": { "type": "boolean" }
      },
      "required": ["id", "type"],
      "additionalProperties": true
    },
    "tagLabel": {
      "type": "object",
      "description": "Inlined from type/tagLabel.json. Official schema requires [tagFQN, source, labelType, state]; relaxed here to only require tagFQN for compatibility with partial API responses.",
      "properties": {
        "tagFQN": { "type": "string" },
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "source": {
          "type": "string",
          "enum": ["Classification", "Glossary"]
        },
        "labelType": {
          "type": "string",
          "enum": ["Manual", "Propagated", "Automated", "Derived", "Generated"]
        },
        "state": {
          "type": "string",
          "enum": ["Suggested", "Confirmed"]
        }
      },
      "required": ["tagFQN"]
    },
    "statusType": {
      "description": "Enum defining the possible Status.",
      "type": "string",
      "enum": ["Successful", "Failed", "Pending", "Skipped"]
    },
    "pipelineState": {
      "description": "Enum defining the possible Pipeline State.",
      "type": "string",
      "enum": ["Active", "Inactive"]
    },
    "task": {
      "type": "object",
      "description": "From definitions.task in the official schema.",
      "properties": {
        "name": {
          "description": "Name that identifies this task instance uniquely.",
          "type": "string"
        },
        "displayName": {
          "description": "Display Name that identifies this Task.",
          "type": "string"
        },
        "fullyQualifiedName": {
          "description": "A unique name that identifies a pipeline in the format 'ServiceName.PipelineName.TaskName'.",
          "type": "string"
        },
        "description": {
          "description": "Description of this Task.",
          "type": "string"
        },
        "sourceUrl": {
          "description": "Task URL to visit/manage.",
          "type": "string",
          "format": "uri"
        },
        "downstreamTasks": {
          "description": "All the tasks that are downstream of this task.",
          "type": ["array", "null"],
          "items": { "type": "string" },
          "default": null
        },
        "taskType": {
          "description": "Type of the Task. Usually refers to the class it implements.",
          "type": "string"
        },
        "taskSQL": {
          "description": "SQL used in the task.",
          "type": ["string", "null"]
        },
        "startDate": {
          "description": "Start date for the task.",
          "type": "string"
        },
        "endDate": {
          "description": "End date for the task.",
          "type": "string"
        },
        "tags": {
          "description": "Tags for this task.",
          "type": "array",
          "items": { "$ref": "#/definitions/tagLabel" },
          "default": []
        }
      },
      "required": ["name"],
      "additionalProperties": true
    },
    "taskStatus": {
      "type": "object",
      "description": "This schema defines a time series of the status of a Pipeline or Task.",
      "properties": {
        "name": {
          "description": "Name of the Task.",
          "type": "string"
        },
        "executionStatus": {
          "description": "Status at a specific execution date.",
          "$ref": "#/definitions/statusType"
        },
        "startTime": {
          "description": "Task start time",
          "type": "number"
        },
        "endTime": {
          "description": "Task end time",
          "type": "number"
        },
        "logLink": {
          "description": "Log link for this task.",
          "type": "string",
          "format": "uri"
        },
        "taskId": {
          "description": "Task ID from orchestrator",
          "type": "string"
        }
      },
      "additionalProperties": true,
      "required": ["name", "executionStatus"]
    },
    "pipelineStatus": {
      "description": "Series of pipeline executions, its status and task status.",
      "type": "object",
      "properties": {
        "timestamp": {
          "description": "Timestamp where the job was executed.",
          "type": "number"
        },
        "executionStatus": {
          "description": "Status at a specific execution date.",
          "$ref": "#/definitions/statusType"
        },
        "taskStatus": {
          "description": "Series of task executions and its status.",
          "type": "array",
          "items": { "$ref": "#/definitions/taskStatus" },
          "default": null
        }
      },
      "additionalProperties": true,
      "required": ["timestamp", "executionStatus"]
    }
  },
  "properties": {
    "id": {
      "description": "Unique identifier that identifies a pipeline instance.",
      "type": "string"
    },
    "name": {
      "description": "Name that identifies this pipeline instance uniquely.",
      "type": "string"
    },
    "displayName": {
      "description": "Display Name that identifies this Pipeline.",
      "type": "string"
    },
    "fullyQualifiedName": {
      "description": "A unique name that identifies a pipeline in the format 'ServiceName.PipelineName'.",
      "type": "string"
    },
    "description": {
      "description": "Description of this Pipeline.",
      "type": "string"
    },
    "version": {
      "description": "Metadata version of the entity.",
      "type": "number"
    },
    "updatedAt": {
      "description": "Last update time in Unix epoch time milliseconds.",
      "type": "number"
    },
    "updatedBy": {
      "description": "User who made the update.",
      "type": "string"
    },
    "sourceUrl": {
      "description": "Pipeline URL to visit/manage.",
      "type": "string",
      "format": "uri"
    },
    "concurrency": {
      "description": "Concurrency of the Pipeline.",
      "type": "integer"
    },
    "pipelineLocation": {
      "description": "Pipeline Code Location.",
      "type": "string"
    },
    "startDate": {
      "description": "Start date of the workflow.",
      "type": "string"
    },
    "endDate": {
      "description": "End date of the workflow.",
      "type": "string"
    },
    "tasks": {
      "description": "All the tasks that are part of pipeline.",
      "type": ["array", "null"],
      "items": { "$ref": "#/definitions/task" },
      "default": null
    },
    "pipelineStatus": {
      "description": "Latest Pipeline Status.",
      "$ref": "#/definitions/pipelineStatus",
      "default": null
    },
    "state": {
      "description": "State of the Pipeline.",
      "$ref": "#/definitions/pipelineState",
      "default": null
    },
    "tags": {
      "description": "Tags for this Pipeline.",
      "type": ["array", "null"],
      "items": { "$ref": "#/definitions/tagLabel" },
      "default": null
    },
    "href": {
      "description": "Link to the resource corresponding to this entity.",
      "type": "string",
      "format": "uri"
    },
    "service": {
      "description": "Link to service where this pipeline is hosted in.",
      "$ref": "#/definitions/entityReference"
    },
    "serviceType": {
      "description": "Service type where this pipeline is hosted in.",
      "type": "string"
    },
    "deleted": {
      "description": "When true indicates the entity has been soft deleted.",
      "type": "boolean",
      "default": false
    },
    "scheduleInterval": {
      "description": "Scheduler Interval for the pipeline in cron format.",
      "type": ["string", "null"],
      "default": null
    },
    "sourceHash": {
      "description": "Source hash of the entity",
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    }
  },
  "required": ["id", "name", "service"],
  "additionalProperties": true
}
