{
  "name": "pipeline-visualizer",
  "version": "1.0.0",
  "description": "Reusable pipeline visualization library",
  "type": "module",
  "main": "dist/pipeline-visualizer.js",
  "module": "dist/pipeline-visualizer.js",
  "exports": {
    ".": "./dist/pipeline-visualizer.js",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "build": "node build.js",
    "build:dev": "node build.js dev",
    "dev": "node build.js watch",
    "check": "tsc --noEmit",
    "test": "node build.js dev && node --experimental-vm-modules tests/run_tests.js",
    "start": "./start.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.27.4",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
